<#
.SYNOPSIS
Скрипт для массового создания пользователей в Active Directory на основе данных из CSV-файла.

.DESCRIPTION
Скрипт читает информацию о пользователях из CSV-файла и создаёт соответствующие учётные записи в домене Active Directory.
Требуется наличие модуля Active Directory для PowerShell (RSAT-AD-PowerShell).

.PARAMETER Path
Путь к CSV-файлу с данными пользователей.

.PARAMETER DefaultOU
OU (Distinguished Name), в которую будут помещены пользователи, если не указано иное в файле данных.
По умолчанию: "CN=Users,DC=domain,DC=local" (замените на свой домен).

.PARAMETER WhatIf
Показывает, какие операции были бы выполнены без фактического создания пользователей.

.EXAMPLE
.\Create-ADUsersFromCSV.ps1 -Path "C:\Data\users.csv" -DefaultOU "OU=Employees,DC=contoso,DC=com"

.EXAMPLE
.\Create-ADUsersFromCSV.ps1 -Path "C:\Data\users.csv" -WhatIf

.NOTES
Требуется запуск от имени администратора домена.
CSV-файл должен содержать заголовки. Обязательные колонки: SamAccountName, Name, GivenName, Surname, UserPrincipalName.
Опциональные колонки: DisplayName, Description, Office, TelephoneNumber, EmailAddress, Department, Company, Title, Manager, StreetAddress, City, State, PostalCode, Country, Password, OU.
Если пароль не указан, будет сгенерирован случайный (выводится в лог).
#>

[CmdletBinding(SupportsShouldProcess=$true)]
param (
    [Parameter(Mandatory=$true)]
    [string]$Path,

    [string]$DefaultOU = "CN=Users,DC=domain,DC=local",   # Замените на свой домен!

    [switch]$WhatIf
)

# Настройка логирования
$script:LogFile = "ADUserCreation_$(Get-Date -Format 'yyyyMMdd_HHmmss').log"
function Write-Log {
    param([string]$Message)
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$timestamp - $Message" | Out-File -FilePath $script:LogFile -Append
    Write-Host "$timestamp - $Message"
}

# Проверка наличия модуля Active Directory
if (-not (Get-Module -ListAvailable -Name ActiveDirectory)) {
    Write-Error "Модуль Active Directory для PowerShell не установлен. Установите RSAT-AD-PowerShell."
    exit 1
}
Import-Module ActiveDirectory -ErrorAction Stop

# Проверка существования файла
if (-not (Test-Path $Path)) {
    Write-Error "Файл не найден: $Path"
    exit 1
}

# Чтение CSV-файла
try {
    $users = Import-Csv -Path $Path -Encoding UTF8
    Write-Log "Загружено записей из CSV: $($users.Count)"
} catch {
    Write-Error "Ошибка чтения CSV-файла: $($_.Exception.Message)"
    exit 1
}

if ($users.Count -eq 0) {
    Write-Log "CSV-файл не содержит данных."
    exit 0
}

# Обязательные поля
$mandatoryFields = @("SamAccountName", "Name", "GivenName", "Surname", "UserPrincipalName")
$optionalFieldsMapping = @{
    "DisplayName"     = "DisplayName"
    "Description"     = "Description"
    "Office"          = "Office"
    "TelephoneNumber" = "Phone"
    "EmailAddress"    = "Email"
    "Department"      = "Department"
    "Company"         = "Company"
    "Title"           = "Title"
    "Manager"         = "Manager"
    "StreetAddress"   = "StreetAddress"
    "City"            = "City"
    "State"           = "State"
    "PostalCode"      = "PostalCode"
    "Country"         = "Country"
}

# Проверка наличия обязательных колонок в первой строке (если есть хотя бы одна строка)
$firstRow = $users[0]
$missingFields = @()
foreach ($field in $mandatoryFields) {
    if ($firstRow.PSObject.Properties.Name -notcontains $field) {
        $missingFields += $field
    }
}
if ($missingFields.Count -gt 0) {
    Write-Error "В CSV отсутствуют обязательные колонки: $($missingFields -join ', ')"
    exit 1
}

# Функция создания пользователя
function New-ADUserFromCSVRow {
    param (
        [pscustomobject]$Row,
        [string]$OU,
        [switch]$WhatIf
    )

    $sam = $Row.SamAccountName
    $name = $Row.Name
    $givenName = $Row.GivenName
    $surname = $Row.Surname
    $upn = $Row.UserPrincipalName

    # Проверка существования пользователя
    if (Get-ADUser -Filter "SamAccountName -eq '$sam'" -ErrorAction SilentlyContinue) {
        Write-Log "Пользователь с SamAccountName '$sam' уже существует. Пропускаем."
        return
    }

    # Пароль: либо из поля Password, либо генерируем случайный
    if ($Row.PSObject.Properties.Name -contains "Password" -and -not [string]::IsNullOrWhiteSpace($Row.Password)) {
        $password = ConvertTo-SecureString -String $Row.Password -AsPlainText -Force
    } else {
        # Генерация случайного пароля (8 символов, буквы и цифры)
        $randomPassword = -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 8 | ForEach-Object { [char]$_ })
        $password = ConvertTo-SecureString -String $randomPassword -AsPlainText -Force
        Write-Log "Для пользователя $sam сгенерирован случайный пароль: $randomPassword (сохраните его!)"
    }

    # Определение OU: если есть колонка OU и она не пустая, используем её, иначе DefaultOU
    $targetOU = $OU
    if ($Row.PSObject.Properties.Name -contains "OU" -and -not [string]::IsNullOrWhiteSpace($Row.OU)) {
        $targetOU = $Row.OU
    }

    # Подготовка параметров для New-ADUser
    $params = @{
        SamAccountName        = $sam
        Name                  = $name
        GivenName             = $givenName
        Surname               = $surname
        UserPrincipalName     = $upn
        AccountPassword       = $password
        Enabled               = $true
        PassThru              = $true
        ChangePasswordAtLogon = $true
        Path                  = $targetOU
        ErrorAction           = "Stop"
    }

    # Добавление опциональных полей, если они присутствуют и не пусты
    foreach ($adField in $optionalFieldsMapping.Keys) {
        $csvField = $optionalFieldsMapping[$adField]
        if ($Row.PSObject.Properties.Name -contains $csvField -and -not [string]::IsNullOrWhiteSpace($Row.$csvField)) {
            $params[$adField] = $Row.$csvField
        }
    }

    # Создание пользователя
    try {
        if ($WhatIf) {
            Write-Log "WhatIf: Создание пользователя $sam в OU $targetOU"
        } else {
            $newUser = New-ADUser @params
            Write-Log "Пользователь $sam успешно создан."
        }
    } catch {
        Write-Log "ОШИБКА при создании пользователя $sam : $($_.Exception.Message)"
    }
}

# Основной цикл по строкам CSV
Write-Log "Начало обработки файла: $Path"
foreach ($row in $users) {
    New-ADUserFromCSVRow -Row $row -OU $DefaultOU -WhatIf:$WhatIf
}

Write-Log "Обработка завершена. Лог сохранён в $script:LogFile"
